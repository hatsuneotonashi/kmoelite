{
  "name": "kmoe-app",
  "private": true,
  "version": "0.1.0",
  "license": "GPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "postbuild": "node ../../scripts/sync-ios-assets.mjs",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest",
    "test:run": "vitest run",
    "verify:release": "../../scripts/verify-release-readiness.sh",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:visual:update": "playwright test e2e/visual.spec.ts --update-snapshots",
    "tauri": "tauri",
    "tauri:info": "tauri info",
    "tauri:build:mac-app": "tauri build --bundles app",
    "tauri:build:mac-app:debug": "tauri build --debug --bundles app",
    "tauri:build:mac-dmg:debug": "../../scripts/package-macos-dmg.sh",
    "tauri:android:init": "tauri android init --ci",
    "tauri:android:build:debug": "tauri android build --debug",
    "tauri:android:run": "tauri android run",
    "tauri:build:windows-msi": "tauri build --bundles msi",
    "tauri:build:windows-nsis": "tauri build --bundles nsis",
    "verify:real-source-zip-reader": "../../scripts/verify-real-source-zip-reader.sh",
    "check:platforms": "node ../../scripts/check-platform-readiness.mjs",
    "check:ios-assets": "node ../../scripts/check-ios-assets.mjs",
    "setup:ios-tools": "../../scripts/setup-ios-local-tools.sh",
    "manifest:release": "node ../../scripts/create-release-manifest.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.12",
    "@tauri-apps/api": "^2.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.555.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.10.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.10.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "jsdom": "^27.2.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vitest": "^4.0.14"
  }
}
